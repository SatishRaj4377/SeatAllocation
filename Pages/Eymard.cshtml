@page
@model EymardModel

@using Syncfusion.EJ2
@using Syncfusion.EJ2.Navigations
@using Syncfusion.EJ2.Diagrams

@{
    ViewData["Title"] = "Eymard Complex";
    Layout = "_Layout";

    var groundFloorHeader = new TabHeader { Text = "Ground Floor" };
    var firstFloorHeader = new TabHeader { Text = "First Floor" };
    var secondFloorHeader = new TabHeader { Text = "Second Floor" };
    var thirdFloorHeader = new TabHeader { Text = "Third Floor" };

    var groundFloorContent = "#groundFloorDiagramContent";
    var firstFloorContent = "#firstFloorDiagramContent";
    var secondFloorContent = "#secondFloorDiagramContent";
    var thirdFloorContent = "#thirdFloorDiagramContent";
}

<!-- Load floor-specific diagram data -->
<script src="~/js/eymard/groundFloor.js"></script>
<script src="~/js/eymard/firstFloor.js"></script>
<script src="~/js/eymard/secondFloor.js"></script>
<script src="~/js/eymard/thirdFloor.js"></script>

<ejs-tab id="eymardTabs" headerPlacement="Left" height="100%" width="100%">
    <e-tab-tabitems>
        <e-tab-tabitem header="@groundFloorHeader" content="@groundFloorContent"></e-tab-tabitem>
        <e-tab-tabitem header="@firstFloorHeader" content="@firstFloorContent"></e-tab-tabitem>
        <e-tab-tabitem header="@secondFloorHeader" content="@secondFloorContent"></e-tab-tabitem>
        <e-tab-tabitem header="@thirdFloorHeader" content="@thirdFloorContent"></e-tab-tabitem>
    </e-tab-tabitems>
</ejs-tab>

<div id="groundFloorDiagramContent" class="diagram-wrapper">
    <ejs-diagram id="eymardGroundFloorDiagram"
                 width="100%"
                 height="650px">
    </ejs-diagram>
    <div class="overview-container">
        <ejs-overview id="eymardGroundFloorOverview" width="100%" height="150px" sourceID="eymardGroundFloorDiagram"></ejs-overview>
    </div>
</div>

<div id="firstFloorDiagramContent" class="diagram-wrapper">
    <ejs-diagram id="eymardFirstFloorDiagram"
                 width="100%"
                 height="650px">
    </ejs-diagram>
    <div class="overview-container">
        <ejs-overview id="eymardFirstFloorOverview" width="100%" height="150px" sourceID="eymardFirstFloorDiagram"></ejs-overview>
    </div>
</div>

<div id="secondFloorDiagramContent" class="diagram-wrapper">
    <ejs-diagram id="eymardSecondFloorDiagram"
                 width="100%"
                 height="650px">
    </ejs-diagram>
    <div class="overview-container">
        <ejs-overview id="eymardSecondFloorOverview" width="100%" height="150px" sourceID="eymardSecondFloorDiagram"></ejs-overview>
    </div>
</div>

<div id="thirdFloorDiagramContent" class="diagram-wrapper">
    <ejs-diagram id="eymardThirdFloorDiagram"
                 width="100%"
                 height="650px">
    </ejs-diagram>
    <div class="overview-container">
        <ejs-overview id="eymardThirdFloorOverview" width="100%" height="150px" sourceID="eymardThirdFloorDiagram"></ejs-overview>
    </div>
</div>