<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SeatAllocation</title>
    <!-- Syncfusion® ASP.NET Core controls styles -->
    <link rel="stylesheet" href="https://cdn.syncfusion.com/ej2/34.1.29/tailwind3.css" />
    <!-- Syncfusion® ASP.NET Core controls scripts -->
    <script src="https://cdn.syncfusion.com/ej2/34.1.29/dist/ej2.min.js"></script>
    <style>
        html, body {
            margin: 0;
            padding: 0;
            height: 100%;
            width: 100%;
            overflow: hidden;
        }
        .diagram-container {
            display: flex;
            height: 100%;
            width: 100%;
        }
        .palette-container {
            width: 250px;
            border-right: 1px solid #e0e0e0;
            overflow-y: auto;
            background-color: #f5f5f5;
        }
        .diagram-content {
            flex: 1;
            overflow: hidden;
        }
        /* Overview Panel Styling */
        .diagram-wrapper {
            position: relative;
            width: 100%;
            height: 100%;
        }
        .overview-container {
            position: absolute;
            bottom: 10px;
            right: 10px;
            width: 200px;
            height: 150px;
            border: 2px solid #e0e0e0;
            background-color: #f9f9f9;
            border-radius: 4px;
            box-shadow: 0px 2px 8px rgba(0, 0, 0, 0.15);
            z-index: 100;
            overflow: hidden;
        }
    </style>
</head>
<body>
    @RenderBody()

    <!-- Syncfusion® ASP.NET Core Script Manager -->
    <ejs-scripts></ejs-scripts>
    
    <!-- Common Diagram Initialization Script -->
    <script src="~/js/diagram-init.js"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
